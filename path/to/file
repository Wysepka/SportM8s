using Microsoft.AspNetCore.Mvc;
using Microsoft.Extensions.Logging;

namespace sportm8s.Controllers
{
    [ApiController]
    [Route("[controller]")]
    public class UserController : ControllerBase
    {
        private readonly ILogger<UserController> _logger;

        public UserController(ILogger<UserController> logger)
        {
            _logger = logger;
        }

        [HttpGet("check-agreement-status")]
        public IActionResult CheckAgreementStatus()
        {
            // Assuming user is fetched from some source
            var user = new User();

            bool isAccepted = user.AgreementAcceptances != null &&
                user.AgreementAcceptances.ContainsKey("PrivacyPolicy");

            _logger.LogInformation("[CheckAgreementStatus] Final agreement {AgreementName} {Accepted}",
                "PrivacyPolicy", isAccepted);

            return Ok(new { isAccepted });
        }
    }
} 